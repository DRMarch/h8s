apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: garage-homelab-local
  namespace: garage
spec:
  secretName: garage-homelab-local-tls
  issuerRef:
    name: vault-issuer
    kind: ClusterIssuer
  commonName: garage.${kubernetes_domain}
  dnsNames:
    - "s3.${kubernetes_domain}"
    - "*.s3.${kubernetes_domain}"
    - "garage.${kubernetes_domain}"
