apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: garage
  namespace: garage
spec:
  parentRefs:
    - name: default-gateway
      namespace: default
      sectionName: home-lan-garage
  hostnames:
    - "s3.${kubernetes_domain}"
    - "*.s3.${kubernetes_domain}"
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /
      backendRefs:
        - name: garage-default-cluster
          port: 3900
