apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: hubble-homelab-local
  namespace: kube-system
spec:
  secretName: hubble-homelab-local-tls
  issuerRef:
    name: vault-issuer
    kind: ClusterIssuer
  commonName: hubble.${kubernetes_domain}
  dnsNames:
    - hubble.${kubernetes_domain}
