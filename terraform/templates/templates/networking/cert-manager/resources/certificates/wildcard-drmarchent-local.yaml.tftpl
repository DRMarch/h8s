apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: wildcard-drmarchent-local
  namespace: cloudflare
spec:
  secretName: wildcard-drmarchent-local-tls
  issuerRef:
    name: vault-issuer
    kind: ClusterIssuer
  commonName: "*.${kubernetes_domain}"
  dnsNames:
    - "*.${kubernetes_domain}"
    - ${kubernetes_domain}
