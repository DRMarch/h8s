apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: bytestash
  namespace: bytestash
spec:
  parentRefs:
    - name: lan-gateway
      namespace: default
      sectionName: home-lan-bytestash
  hostnames:
    - bytestash.${kubernetes_domain}
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /
      backendRefs:
        - name: bytestash
          port: 5000
